---
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { getSortedPosts } from "@utils/content-utils";
import { postConfig } from "../../../config";

export async function getStaticPaths() {
    const blogEntries = await getSortedPosts();
    const renderedEntries = await Promise.all(
        blogEntries.map(async (entry) => {
            const { remarkPluginFrontmatter } = await entry.render();
            return {
                entry,
                needsDisclaimer: remarkPluginFrontmatter?.needsDisclaimer === true,
            };
        })
    );
    return renderedEntries
        .filter(({ needsDisclaimer }) => needsDisclaimer)
        .map(({ entry }) => ({
            params: { slug: entry.slug },
            props: { entry },
        }));
}

const { entry } = Astro.props;
const { remarkPluginFrontmatter } = await entry.render();
const customDisclaimer = remarkPluginFrontmatter?.customDisclaimer;
const postUrl = `/posts/${entry.slug}/`;
---

<MainGridLayout
    title={`${postConfig.disclaimerTitle} - ${entry.data.title}`}
    description={entry.data.description}
    lang={entry.data.lang}
>
    <div
        class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative mb-4 min-h-[60vh]"
    >
        <div
            class="card-base z-10 px-6 md:px-9 pt-8 pb-8 relative w-full flex flex-col items-center justify-center"
        >
            <h1
                class="text-2xl font-bold mb-2 text-center text-black/90 dark:text-white/90"
            >
                {postConfig.disclaimerTitle}
            </h1>
            <p
                class="text-sm text-neutral-500 dark:text-neutral-400 mb-8 text-center"
            >
                {entry.data.title}
            </p>
            <div
                class="max-w-lg w-full space-y-3 text-sm text-neutral-700 dark:text-neutral-300 mb-8"
                set:html={customDisclaimer || postConfig.disclaimerContent.map((para: string) => `<p>${para.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;")}</p>`).join("")}
            />
            <button
                id="disclaimer-agree-btn"
                class="btn-regular w-full max-w-lg py-3 rounded-lg font-medium text-center"
                data-slug={entry.slug}
            >
                我已阅读并同意，继续阅读文章
            </button>
        </div>
    </div>
    <script is:inline define:vars={{ postUrl }}>
        (function () {
            const btn = document.getElementById("disclaimer-agree-btn");
            if (!btn) return;
            btn.addEventListener("click", function () {
                sessionStorage.setItem(
                    "disclaimer_" + this.dataset.slug,
                    "1"
                );
                window.location.href = postUrl;
            });
        })();
    </script>
</MainGridLayout>
